{
  "name": "vidion-backend",
  "version": "2.0.0",
  "description": "Vidion – YouTube clone backend (Fastify + TypeScript + youtubei.js)",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/jobs/worker.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.0.1",
    "@prisma/client": "5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.56.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.0",
    "pino-pretty": "^13.0.0",
    "prisma": "5",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "youtubei.js": "^16.0.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.15.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
